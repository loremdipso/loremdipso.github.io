{
  "name": "loremdipso.github.io",
  "private": true,
  "description": "A simplified bare-bones starter for Gatsby",
  "version": "0.1.0",
  "license": "0BSD",
  "scripts": {
    "resume": "node ./resume/build.js",
    "build": "gatsby build && node ./resume/build.js && rm -rf ./docs; cp -r ./public ./docs",
    "debug": "gatsby develop",
    "develop": "gatsby develop",
    "dev": "gatsby develop",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "start": "npm run develop",
    "serve": "gatsby serve",
    "clean": "gatsby clean",
    "test": "echo \"Write tests! -> https://gatsby.dev/unit-testing\" && exit 1"
  },
  "dependencies": {
    "bootstrap": "^4.5.3",
    "gatsby": "^2.30.1",
    "gatsby-plugin-catch-links": "^2.8.0",
    "gatsby-plugin-react-helmet": "^3.8.0",
    "gatsby-plugin-sass": "^2.8.0",
    "gatsby-remark-prismjs": "^3.11.0",
    "gatsby-source-filesystem": "^2.9.0",
    "gatsby-transformer-remark": "^2.14.0",
    "js-yaml": "^3.14.1",
    "json2md": "^1.9.2",
    "ncp": "^2.0.0",
    "node-sass": "^4.14.1",
    "puppeteer": "^5.5.0",
    "react": "^16.14.0",
    "react-bootstrap": "^1.4.3",
    "react-custom-icons": "^1.0.21",
    "react-dom": "^16.14.0",
    "react-helmet": "^6.1.0",
    "react-icons": "^3.11.0",
    "react-router-dom": "^5.2.0",
    "recoil": "0.0.13"
  },
  "devDependencies": {
    "gh-pages": "^3.1.0",
    "prettier": "2.0.5",
    "react-ga": "^3.3.0"
  }
}
