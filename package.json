    "gatsby-source-filesystem": "^2.3.23",
    "gatsby-transformer-remark": "^2.8.27",
    "js-yaml": "^3.14.0",
    "json2md": "^1.7.0",
    "ncp": "^2.0.0",
    "node-sass": "^4.14.1",
    "react": "^16.12.0",
    "react-bootstrap": "^1.3.0",
    "react-custom-icons": "^1.0.21",
    "react-dom": "^16.12.0",
    "react-helmet": "^6.1.0",
    "react-icons": "^3.10.0",
